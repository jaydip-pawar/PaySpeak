    <string name="home_perm_accessibility_desc">Payment detection may be less reliable in some apps.</string>
    <string name="home_perm_battery_title">Background activity restricted</string>
    <string name="home_perm_battery_desc">Announcements may stop working when your screen is off.</string>
    <string name="home_perm_autostart_title">Autostart blocked by your device</string>
    <string name="home_perm_autostart_desc">Your device may stop PaySpeak after clearing recent apps. Enable autostart in your device settings to make sure payment announcements always work.</string>
