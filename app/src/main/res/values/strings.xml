    <string name="onboarding_improve_title">Help improve payment detection</string>
    <string name="onboarding_improve_description">If a payment cannot be recognized properly, PaySpeak can share an anonymized example to help improve detection accuracy.</string>
    <string name="onboarding_improve_privacy_note">Sensitive numbers and identifiers are masked before sharing.</string>
    <string name="onboarding_improve_toggle_title">Improve detection</string>
    <string name="onboarding_improve_toggle_desc">Help improve payment detection in future updates.</string>

