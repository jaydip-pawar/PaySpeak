    <string name="home_perm_notif_access_desc">You may miss instant payment alerts from apps like GPay and PhonePe.</string>
    <string name="home_perm_post_notif_title">App notifications turned off</string>
    <string name="home_perm_post_notif_desc">You won\'t hear confirmations or important alerts from PaySpeak.</string>
    <string name="home_perm_sms_title">SMS access not enabled</string>
    <string name="home_perm_sms_desc">Some bank payments may not be detected if they don\'t send app notifications.</string>
