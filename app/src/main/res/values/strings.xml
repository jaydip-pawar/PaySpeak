    <!-- Onboarding - Screen 3: Privacy -->
    <string name="onboarding_privacy_title">Private, simple, and in your control</string>
    <string name="onboarding_privacy_description">PaySpeak processes payment detection locally on your phone. Your transaction history stays on your device.</string>
    <string name="onboarding_privacy_info">You stay in control of which permissions to enable.</string>
    <string name="onboarding_privacy_no_login_title">No login required</string>
