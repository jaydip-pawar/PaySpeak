<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Text Appearances -->
    <style name="TextAppearance.PaySpeak.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.PaySpeak.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
    </style>

    <style name="TextAppearance.PaySpeak.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/md_theme_onSurfaceVariant</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="TextAppearance.PaySpeak.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/md_theme_onSurfaceVariant</item>
    </style>

    <style name="TextAppearance.PaySpeak.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/md_theme_onSurfaceVariant</item>
    </style>

    <style name="TextAppearance.PaySpeak.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
    </style>

    <style name="TextAppearance.PaySpeak.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/md_theme_onSurfaceVariant</item>
    </style>

    <style name="TextAppearance.PaySpeak.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/md_theme_onSurfaceVariant</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.PaySpeak.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/btn_primary_text_tint</item>
        <item name="backgroundTint">@color/btn_primary_bg_tint</item>
        <item name="cornerRadius">@dimen/radius_button</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.PaySpeak.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/md_theme_onPrimaryContainer</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Switch Style (green when checked) -->
    <style name="Widget.PaySpeak.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">@color/switch_thumb_color</item>
        <item name="trackTint">@color/switch_track_color</item>
    </style>

</resources>
