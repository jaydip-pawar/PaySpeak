<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/onboarding_horizontal_padding"
        android:paddingTop="@dimen/spacing_xxl"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_how_it_works_title"
            android:textAppearance="@style/TextAppearance.PaySpeak.HeadlineMedium"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_how_it_works_description"
            android:textAppearance="@style/TextAppearance.PaySpeak.BodyLarge"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_how_it_works_hint"
            android:textAppearance="@style/TextAppearance.PaySpeak.BodySmall"
            android:textColor="@color/md_theme_onPrimaryContainer"
            android:layout_marginBottom="@dimen/spacing_xxl" />

        <!-- Notifications Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_surface"
            android:padding="@dimen/spacing_xl"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_lg">

            <FrameLayout
                android:layout_width="@dimen/icon_container_size"
                android:layout_height="@dimen/icon_container_size"
                android:background="@drawable/bg_icon_rounded_green">

                <ImageView
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_notifications"
                    app:tint="@color/md_theme_onSecondaryContainer"
                    android:contentDescription="@null" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_method_notifications"
                    android:textAppearance="@style/TextAppearance.PaySpeak.LabelLarge"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_method_notifications_desc"
                    android:textAppearance="@style/TextAppearance.PaySpeak.BodySmall"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchNotifications"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                style="@style/Widget.PaySpeak.Switch" />
        </LinearLayout>

        <!-- SMS Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_surface"
            android:padding="@dimen/spacing_xl"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_lg">

            <FrameLayout
                android:layout_width="@dimen/icon_container_size"
                android:layout_height="@dimen/icon_container_size"
                android:background="@drawable/bg_icon_rounded_gray">

                <ImageView
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_sms"
                    app:tint="@color/md_theme_onSurfaceVariant"
                    android:contentDescription="@null" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_method_sms"
                    android:textAppearance="@style/TextAppearance.PaySpeak.LabelLarge"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_method_sms_desc"
                    android:textAppearance="@style/TextAppearance.PaySpeak.BodySmall"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchSms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                style="@style/Widget.PaySpeak.Switch" />
        </LinearLayout>

        <!-- Accessibility Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_surface"
            android:padding="@dimen/spacing_xl"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="@dimen/icon_container_size"
                android:layout_height="@dimen/icon_container_size"
                android:background="@drawable/bg_icon_rounded_gray">

                <ImageView
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_accessibility"
                    app:tint="@color/md_theme_onSurfaceVariant"
                    android:contentDescription="@null" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_method_accessibility"
                    android:textAppearance="@style/TextAppearance.PaySpeak.LabelLarge"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_method_accessibility_desc"
                    android:textAppearance="@style/TextAppearance.PaySpeak.BodySmall"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchAccessibility"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                style="@style/Widget.PaySpeak.Switch" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
