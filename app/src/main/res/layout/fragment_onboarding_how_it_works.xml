<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/onboarding_horizontal_padding"
        android:paddingTop="@dimen/spacing_xxl"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_how_it_works_title"
            android:textAppearance="@style/TextAppearance.PaySpeak.HeadlineMedium"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_how_it_works_description"
            android:textAppearance="@style/TextAppearance.PaySpeak.BodyLarge"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Hint -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_info_chip"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_sm"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_xxl">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_info"
                app:tint="@color/md_theme_onSurfaceVariant"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_how_it_works_hint"
                android:textAppearance="@style/TextAppearance.PaySpeak.LabelSmall"
                android:layout_marginStart="@dimen/spacing_sm" />
        </LinearLayout>

        <!-- Notifications Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_surface"
            android:padding="@dimen/spacing_xl"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_lg">

            <FrameLayout
                android:id="@+id/containerNotificationsIcon"
                android:layout_width="@dimen/icon_container_size"
                android:layout_height="@dimen/icon_container_size"
                android:background="@drawable/bg_icon_rounded_white">

                <ImageView
                    android:id="@+id/iconNotifications"
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_notifications_active"
                    app:tint="@color/md_theme_secondary"
                    android:contentDescription="@null" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/onboarding_method_notifications"
                        android:textAppearance="@style/TextAppearance.PaySpeak.LabelLarge"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_badge_recommended"
                        android:textAllCaps="true"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:paddingHorizontal="@dimen/spacing_sm"
                        android:paddingVertical="2dp"
                        android:background="@drawable/bg_badge_recommended"
                        android:textColor="@color/md_theme_onSecondaryContainer" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_method_notifications_desc"
                    android:textAppearance="@style/TextAppearance.PaySpeak.BodySmall"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- SMS Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_surface"
            android:padding="@dimen/spacing_xl"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_lg">

            <FrameLayout
                android:id="@+id/containerSmsIcon"
                android:layout_width="@dimen/icon_container_size"
                android:layout_height="@dimen/icon_container_size"
                android:background="@drawable/bg_icon_rounded_white">

                <ImageView
                    android:id="@+id/iconSms"
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_sms"
                    app:tint="@color/md_theme_secondary"
                    android:contentDescription="@null" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/onboarding_method_sms"
                        android:textAppearance="@style/TextAppearance.PaySpeak.LabelLarge"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_badge_optional"
                        android:textAllCaps="true"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:paddingHorizontal="@dimen/spacing_sm"
                        android:paddingVertical="2dp"
                        android:background="@drawable/bg_badge_optional"
                        android:textColor="@color/md_theme_onSurfaceVariant" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_method_sms_desc"
                    android:textAppearance="@style/TextAppearance.PaySpeak.BodySmall"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Accessibility Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_surface"
            android:padding="@dimen/spacing_xl"
            android:gravity="center_vertical">

            <FrameLayout
                android:id="@+id/containerAccessibilityIcon"
                android:layout_width="@dimen/icon_container_size"
                android:layout_height="@dimen/icon_container_size"
                android:background="@drawable/bg_icon_rounded_white">

                <ImageView
                    android:id="@+id/iconAccessibility"
                    android:layout_width="@dimen/icon_size_medium"
                    android:layout_height="@dimen/icon_size_medium"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_accessibility"
                    app:tint="@color/md_theme_secondary"
                    android:contentDescription="@null" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/onboarding_method_accessibility"
                        android:textAppearance="@style/TextAppearance.PaySpeak.LabelLarge"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_badge_optional"
                        android:textAllCaps="true"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:paddingHorizontal="@dimen/spacing_sm"
                        android:paddingVertical="2dp"
                        android:background="@drawable/bg_badge_optional"
                        android:textColor="@color/md_theme_onSurfaceVariant" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_method_accessibility_desc"
                    android:textAppearance="@style/TextAppearance.PaySpeak.BodySmall"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
