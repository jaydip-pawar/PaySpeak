<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/onboarding_horizontal_padding"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_lg"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_privacy_title"
            android:textAppearance="@style/TextAppearance.PaySpeak.HeadlineMedium"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_privacy_description"
            android:textAppearance="@style/TextAppearance.PaySpeak.BodyLarge"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Info badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_info_chip"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingVertical="@dimen/spacing_sm"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_xxl">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_info"
                app:tint="@color/md_theme_onSurfaceVariant"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_privacy_info"
                android:textAppearance="@style/TextAppearance.PaySpeak.LabelSmall"
                android:layout_marginStart="@dimen/spacing_sm" />
        </LinearLayout>

        <!-- Feature Card 1: No login required -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_surface"
            android:padding="@dimen/card_padding"
            android:gravity="top"
            android:layout_marginBottom="@dimen/spacing_md">

            <FrameLayout
                android:layout_width="@dimen/icon_container_small"
                android:layout_height="@dimen/icon_container_small"
                android:background="@drawable/bg_icon_rounded_white"
                android:elevation="1dp">

                <ImageView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    app:tint="@color/md_theme_secondary"
                    android:contentDescription="@null" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_privacy_no_login_title"
                    android:textAppearance="@style/TextAppearance.PaySpeak.LabelLarge" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_privacy_no_login_desc"
                    android:textAppearance="@style/TextAppearance.PaySpeak.LabelSmall"
                    android:layout_marginTop="@dimen/spacing_xs" />
            </LinearLayout>
        </LinearLayout>

        <!-- Feature Card 2: Permissions optional -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_surface"
            android:padding="@dimen/card_padding"
            android:gravity="top"
            android:layout_marginBottom="@dimen/spacing_md">

            <FrameLayout
                android:layout_width="@dimen/icon_container_small"
                android:layout_height="@dimen/icon_container_small"
                android:background="@drawable/bg_icon_rounded_white"
                android:elevation="1dp">

                <ImageView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/md_theme_secondary"
                    android:contentDescription="@null" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_privacy_permissions_title"
                    android:textAppearance="@style/TextAppearance.PaySpeak.LabelLarge" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_privacy_permissions_desc"
                    android:textAppearance="@style/TextAppearance.PaySpeak.LabelSmall"
                    android:layout_marginTop="@dimen/spacing_xs" />
            </LinearLayout>
        </LinearLayout>

        <!-- Feature Card 3: Works with notifications -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_surface"
            android:padding="@dimen/card_padding"
            android:gravity="top">

            <FrameLayout
                android:layout_width="@dimen/icon_container_small"
                android:layout_height="@dimen/icon_container_small"
                android:background="@drawable/bg_icon_rounded_white"
                android:elevation="1dp">

                <ImageView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/md_theme_secondary"
                    android:contentDescription="@null" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/spacing_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_privacy_notifications_title"
                    android:textAppearance="@style/TextAppearance.PaySpeak.LabelLarge" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_privacy_notifications_desc"
                    android:textAppearance="@style/TextAppearance.PaySpeak.LabelSmall"
                    android:layout_marginTop="@dimen/spacing_xs" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
