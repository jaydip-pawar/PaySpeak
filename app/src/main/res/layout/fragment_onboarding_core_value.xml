<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="@dimen/onboarding_horizontal_padding"
        android:paddingTop="@dimen/spacing_xxl"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- Illustration -->
        <FrameLayout
            android:layout_width="@dimen/onboarding_illustration_size"
            android:layout_height="@dimen/onboarding_illustration_size"
            android:layout_marginBottom="@dimen/spacing_xxxl">

            <!-- Outer soft glow circle -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.2"
                android:background="@drawable/bg_icon_circle_green" />

            <!-- Inner icon circle -->
            <FrameLayout
                android:layout_width="@dimen/onboarding_illustration_inner"
                android:layout_height="@dimen/onboarding_illustration_inner"
                android:layout_gravity="center"
                android:background="@drawable/bg_icon_circle_green">

                <ImageView
                    android:layout_width="@dimen/onboarding_illustration_icon"
                    android:layout_height="@dimen/onboarding_illustration_icon"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_record_voice_over"
                    app:tint="@color/md_theme_onSecondaryContainer"
                    android:contentDescription="@null" />
            </FrameLayout>
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvCoreValueTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_core_value_title"
            android:textAppearance="@style/TextAppearance.PaySpeak.HeadlineLarge"
            android:textAlignment="center"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_core_value_description"
            android:textAppearance="@style/TextAppearance.PaySpeak.BodyLarge"
            android:textAlignment="center" />

    </LinearLayout>
</ScrollView>
